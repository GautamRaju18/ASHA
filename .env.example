# Copy to backend/.env (or set as environment variables) to override defaults.
# Defaults are FREE and require no key (Ollama local + OpenStreetMap).

# --- LLM provider ---
# ollama (local, free) | gemini (free tier) | kimi (Moonshot) | anthropic (paid)
ASHA_LLM_PROVIDER=ollama
ASHA_OLLAMA_MODEL=llama3.2:latest
OLLAMA_BASE_URL=http://localhost:11434

# Gemini (free tier, OpenAI-compatible). Set provider=gemini to use it.
# Note: free-tier models/quotas vary by key — gemini-2.5-flash works broadly;
# the app auto-retries on 429 rate limits.
# GEMINI_API_KEY=
# ASHA_GEMINI_MODEL=gemini-2.5-flash

# Kimi / Moonshot (OpenAI-compatible). Set provider=kimi to use it.
# KIMI_API_KEY=
# ASHA_KIMI_MODEL=kimi-latest

# Anthropic (paid, optional):
# ANTHROPIC_API_KEY=
# ASHA_ANTHROPIC_MODEL=claude-opus-4-8

# --- Retrieval ---
ASHA_USE_DENSE=1
ASHA_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
ASHA_TOP_K=6

# --- Facilities (free OSM) ---
ASHA_FACILITY_RADIUS_M=15000
ASHA_FACILITY_N=5
ASHA_HELPLINE=108
